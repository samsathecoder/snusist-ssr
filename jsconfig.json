{
  "compilerOptions": {
    "baseUrl": "src",
    "paths": {
      "@/*": ["*"],
      "@lib/*": ["lib/*"],
      "@components/*": ["components/*"],
      "@types/*": ["types/*"],
      "@data/*": ["data/*"],
      "@styles/*": ["styles/*"],
      "@models/*": ["models/*"],
       "@StructedData/*": ["StructedData/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
